DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mealplan
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_FAST_MODEL=openai/gpt-4o-mini
LLM_HEAVY_MODEL=openai/gpt-4o
LLM_CONCURRENCY=5
CONTAINER_GROUPING_AI=true
DEBUG=true

# Google sign-in (same OAuth client ID as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
JWT_SECRET=change-me-to-a-long-random-string
ALLOWED_EMAIL=hayeson@gmail.com
CORS_ORIGINS=http://localhost:5173,http://localhost:8000
SERVE_STATIC=false

# Social recipe import (TikTok / Instagram) — optional
SOCIAL_VIDEO_EXTRACTION=true
SOCIAL_IMPORT_TIMEOUT_SECS=120
INSTAGRAM_COOKIES_FILE=
WHISPER_MODEL=whisper-1
FFMPEG_PATH=
